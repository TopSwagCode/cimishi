#!/usr/bin/env bash
# Pre-push hook - runs CI checks before allowing push
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

echo "🔍 Running pre-push CI checks..."

# Quick format check (fast)
echo "📝 Checking formatting..."
cargo fmt --all -- --check || {
    echo "❌ Format check failed. Run 'cargo fmt' to fix."
    exit 1
}

# Clippy with warnings as errors (medium)
echo "📎 Running Clippy..."
cargo clippy --all-targets -- -D warnings || {
    echo "❌ Clippy found issues. Fix them before pushing."
    exit 1
}

# Tests (slowest)
echo "🧪 Running tests..."
cargo test || {
    echo "❌ Tests failed. Fix them before pushing."
    exit 1
}

echo "✅ All checks passed!"
