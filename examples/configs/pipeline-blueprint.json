{
  "pipeline": {
    "name": "example-pipeline",
    "parallel": true,
    "max_concurrent": 10
  },
  "sources": [
    {
      "type": "local",
      "path": ".cimishi/data",
      "patterns": ["*.xml", "*.rdf", "*.zip", "*.gz"],
      "recursive": true
    }
  ],
  "processors": [
    {
      "type": "unzip",
      "archive_patterns": ["*.zip"],
      "gzip_patterns": ["*.gz", "*.gzip"],
      "patterns": ["*.xml", "*.rdf"]
    },
    {
      "type": "filter",
      "exclude": ["._*", "__MACOSX/*"]
    }
  ],
  "query": {
    "file": ".cimishi/query/example-query.sparql",
    "base_iri": "http://example.org/"
  },
  "output": {
    "dir": ".cimishi/output",
    "formats": ["csv", "json", "terminal"],
    "metadata": true,
    "prefix": "example-results"
  }
}
